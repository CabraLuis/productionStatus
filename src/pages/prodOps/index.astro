---
import Navbar from "../../components/prod/Navbar";
import ProdOpsModule from "../../components/prod/ProdOpsModule";
import Layout from "../../layouts/Layout.astro";

let value;
let deliverToValue;

if (Astro.cookies.has("area")) {
  const cookie = Astro.cookies.get("area");
  value = cookie?.value;
}

if (Astro.cookies.has("deliverTo")) {
  const cookie = Astro.cookies.get("deliverTo");
  deliverToValue = cookie?.value;
}
---

<Layout title="Nueva WorkOrder">
  <Navbar client:load />
  <ProdOpsModule deliverTo={deliverToValue} deliveredBy={value} client:load />
</Layout>
